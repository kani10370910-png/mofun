# ============================================================
# MOFUN 魔方智绘平台 · 文案生成 LLM 配置
# 复制本文件为 .env.local 并填入真实值。.env.local 不会进 git / 前端 bundle。
# ============================================================

# provider 预设：deepseek | qwen | glm | ernie | custom
# 选定 provider 后，baseURL 与默认 model 会自动套用，可被下面的变量覆盖。
LLM_PROVIDER=deepseek

# OpenAI 兼容 baseURL（留空则用 provider 预设值）
# deepseek : https://api.deepseek.com/v1
# qwen(通义): https://dashscope.aliyuncs.com/compatible-mode/v1
# glm(智谱) : https://open.bigmodel.cn/api/paas/v4
LLM_BASE_URL=

# ★ 你的 API Key（必填，绝不要提交到 git）
LLM_API_KEY=

# 模型名（留空则用 provider 预设值，如 deepseek-chat / qwen-plus / glm-4-plus）
LLM_MODEL=

# 上游请求超时（毫秒）
LLM_TIMEOUT_MS=60000
